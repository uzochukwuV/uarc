# WalletConnect Project ID
# Get one at https://cloud.walletconnect.com
VITE_WALLETCONNECT_PROJECT_ID=your_project_id_here

# Alchemy API Key (optional, for better RPC)
# Get one at https://www.alchemy.com
VITE_ALCHEMY_API_KEY=your_alchemy_key_here

# Chain ID
VITE_CHAIN_ID=80001  # Polygon Mumbai testnet

# Contract Addresses (update after deployment)
VITE_TASK_FACTORY_ADDRESS=0x...
VITE_EXECUTOR_HUB_ADDRESS=0x...
VITE_GLOBAL_REGISTRY_ADDRESS=0x...
VITE_ACTION_REGISTRY_ADDRESS=0x...
VITE_REWARD_MANAGER_ADDRESS=0x...
