      "examples": [
        "Swap 100 USDC for ETH",
        "Trade 50 USDT for WETH with 0.3% fee",
        "Convert 200 USDC to WETH"
      ]
    },
    {
      "id": "uniswap_dca",
      "adapter": "0x6E5E28e08448409c63F8256908F81999B6DA4DBb",
      "description": "Dollar-cost averaging - recurring swaps on Uniswap V3",
      "params": [
        "taskId:bytes32",
        "tokenIn:address",
        "tokenOut:address",
        "fee:uint24 (500=0.05%, 3000=0.3%, 10000=1%)",
        "amountPerSwap:uint256",
        "interval:uint256 (seconds between swaps)",
        "totalSwaps:uint256 (0=unlimited)",
        "minAmountOut:uint256",
        "recipient:address"
      ],
      "examples": [
        "DCA $100 USDC into ETH every week for 12 weeks",
        "Buy $50 worth of WETH daily",
        "Accumulate ETH with $200 USDC monthly"
      ]
    },
    {
      "id": "uniswap_limit_order",
      "adapter": "0x504f73A97E2b7c34e98C3006cB7f237F864a67B0",
      "description": "Limit orders and stop-loss on Uniswap V3",
      "params": [
        "orderId:bytes32",
        "tokenIn:address",
        "tokenOut:address",
        "fee:uint24 (500=0.05%, 3000=0.3%, 10000=1%)",
        "amountIn:uint256",
        "targetPrice:uint256 (18 decimals)",
        "orderType:uint8 (0=LIMIT_BUY, 1=LIMIT_SELL, 2=STOP_LOSS, 3=TAKE_PROFIT)",
        "minAmountOut:uint256",
        "recipient:address",
        "expiry:uint256 (0=no expiry)"
      ],
      "examples": [
        "Sell 1 ETH when price reaches $4000",
        "Buy ETH if price drops to $2500",
        "Set stop-loss at $2000 for my ETH",
