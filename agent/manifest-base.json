      "adapter": "0x17e7bA6d4939f7e826ca9aE06C76177E25691A61",
      "description": "Send tokens on a recurring schedule (weekly, monthly)",
      "params": [
        "token:address",
        "recipient:address",
        "amountPerExecution:uint256",
        "startTime:uint256",
        "interval:uint256",
